'use client';

import React, { useEffect, useState } from 'react';
import { useSearchParams } from 'next/navigation';

export default function ResultPage() {
  const searchParams = useSearchParams();
  const goal = searchParams.get('goal');
  const level = searchParams.get('level');
  const [recommendation, setRecommendation] = useState('');
  const [programName, setProgramName] = useState('');

  // מספר הטלפון המעודכן שלך בוואטסאפ
  const myPhoneNumber = '972559939351'; 

  useEffect(() => {
    // התאמת שם הפרוטוקול וההסבר הכללי לפי בחירת המשתמש
    if (goal === 'build' && level === 'beginner') {
      setProgramName('Hypertrophy-X');
      setRecommendation('פרוטוקול כוח והיפרטרופיה מותאם למתחילים: דגש על למידת טכניקה, בניית בסיס חזק ועלייה נקייה במסת השריר.');
    } else if (goal === 'build' && level === 'advanced') {
      setProgramName('Power-Builder Elite');
      setRecommendation('תוכנית מתקדמת המשלבת כוח מרבי ונפח עבודה גבוה: חלוקת אימונים אגרסיבית ומניעת פלאטו.');
    } else if (goal === 'shred' && level === 'beginner') {
      setProgramName('Burn-Fat Starter');
      setRecommendation('פרוטוקול שריפת שומן מואצת למתחילים: שילוב אימוני התנגדות ואירובי מבוקר לשמירה על מסת שריר תוך כדי ירידה באחוזי השומן.');
    } else if (goal === 'shred' && level === 'advanced') {
      setProgramName('Shred-Protocol Pro');
      setRecommendation('תוכנית חיטוב קיצונית למתקדמים: שיטות אינטנסיביות לשריפת שומן עקשן, ניהול תזונה קפדני ושימור כוח מרבי.');
    } else {
      setProgramName('Lifestyle Balance');
      setRecommendation('פרוטוקול שיפור הרכב גוף ואורח חיים בריא: דגש על התמדה, שיפור מדדי בריאות וכושר כללי גבוה.');
    }
  }, [goal, level]);

  // תרגום הערכים לעברית קריאה בשביל הודעת הוואטסאפ
  const getGoalHebrew = (g: string | null) => {
    if (g === 'build') return 'עלייה במסה';
    if (g === 'shred') return 'חיטוב אגרסיבי';
    return 'כושר ואורח חיים';
  };

  const getLevelHebrew = (l: string | null) => {
    return l === 'advanced' ? 'מתקדם (מעל שנה)' : 'מתחיל (פחות משנה)';
  };

  // יצירת קישור וואטסאפ עם הודעה מובנית אישית
  const goalHeb = getGoalHebrew(goal);
  const levelHeb = getLevelHebrew(level);
  const whatsappMessage = `היי יצחק, עשיתי את השאלון באתר! יצא שאני מתאים לתוכנית: *${programName}*. \n\nהפרטים שלי:\n- מטרה: ${goalHeb}\n- רמת ניסיון: ${levelHeb}\n\nאשמח לקבל את פרטי התוכנית המלאה ולהתחיל לשתף פעולה! 🚀`;
  const whatsappUrl = `https://wa.me/${myPhoneNumber}?text=${encodeURIComponent(whatsappMessage)}`;

  return (
    <div className="min-h-screen bg-black text-white p-6 flex flex-col items-center justify-center font-sans selection:bg-lime-400 selection:text-black">
      <div className="max-w-2xl w-full bg-gray-950 p-8 md:p-12 rounded-3xl border border-gray-900 text-center shadow-2xl relative overflow-hidden">
        
        {/* אלמנטים עיצוביים ברקע */}
        <div className="absolute -top-10 -left-10 w-40 h-40 bg-lime-500/10 rounded-full blur-3xl"></div>
        <div className="absolute -bottom-10 -right-10 w-40 h-40 bg-lime-500/10 rounded-full blur-3xl"></div>

        <span className="text-lime-400 font-mono tracking-widest text-xs uppercase border border-lime-400/30 px-3 py-1 rounded-full bg-lime-950/20">
          YOUR FITNESS PROTOCOL
        </span>

        <h1 className="text-4xl font-black mt-6 mb-2">הפרוטוקול שלך מוכן!</h1>
        <p className="text-gray-400 text-base mb-8">ניתחנו את הנתונים שלך בהתאם למטרה ולרמת הניסיון.</p>
        
        <div className="bg-black/50 p-6 rounded-2xl border border-gray-800 mb-8 text-right space-y-3">
          <div className="flex justify-between border-b border-gray-900 pb-2">
            <span className="text-gray-500 text-sm">פרוטוקול מותאם:</span>
            <span className="text-lime-400 font-bold">{programName}</span>
          </div>
          <div className="flex justify-between border-b border-gray-900 pb-2">
            <span className="text-gray-500 text-sm">מטרה מרכזית:</span>
            <span className="text-white font-semibold">{goalHeb}</span>
          </div>
          <div className="flex justify-between pb-1">
            <span className="text-gray-500 text-sm">רמת ניסיון:</span>
            <span className="text-white font-semibold">{levelHeb}</span>
          </div>
        </div>

        <div className="bg-gradient-to-r from-lime-950/20 to-emerald-950/20 p-6 rounded-2xl border border-lime-500/20 mb-10 text-center">
          <p className="text-gray-300 leading-relaxed text-lg">{recommendation}</p>
        </div>

        {/* כפתור הוואטסאפ הגדול והרוטט למשיכת הליד */}
        <div className="space-y-4">
          <a 
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            className="block w-full bg-lime-400 hover:bg-lime-500 text-black font-extrabold py-5 px-6 rounded-2xl text-xl transition duration-300 transform hover:-translate-y-1 shadow-[0_0_25px_rgba(163,230,53,0.3)] animate-pulse"
          >
            שלח לי את התוכנית המלאה בוואטסאפ 🚀
          </a>
          
          <button 
            onClick={() => window.location.href = '/'}
            className="text-gray-500 hover:text-white transition text-sm font-semibold"
          >
            ← חזרה לדף הבית
          </button>
        </div>
      </div>
    </div>
  );
}
