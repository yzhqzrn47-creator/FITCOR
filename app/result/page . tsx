'use client';

import React, { useEffect, useState } from 'react';
import { useSearchParams } from 'next/navigation';

export default function ResultPage() {
  const searchParams = useSearchParams();
  const goal = searchParams.get('goal');
  const level = searchParams.get('level');
  const [recommendation, setRecommendation] = useState('');

  useEffect(() => {
    // לוגיקת ההמלצות
    if (goal === 'build' && level === 'beginner') {
      setRecommendation('תוכנית Hypertrophy-X: אימוני כוח 3 פעמים בשבוע + תפריט עלייה במסה נקייה.');
    } else if (goal === 'build' && level === 'advanced') {
      setRecommendation('תוכנית Power-Builder Elite: אימוני כוח מפוצלים 5 פעמים בשבוע + העמסת פחמימות מבוקרת.');
    } else if (goal === 'shred' && level === 'beginner') {
      setRecommendation('תוכנית Burn-Fat Starter: אימוני Full Body + אירובי קל + גירעון קלורי מתון.');
    } else if (goal === 'shred' && level === 'advanced') {
      setRecommendation('תוכנית Shred-Protocol: אימוני HIIT + נפח אימונים גבוה + תפריט עשיר בחלבון.');
    } else {
      setRecommendation('תוכנית Lifestyle Balance: שיפור כושר כללי, גמישות ואורח חיים בריא.');
    }
  }, [goal, level]);

  return (
    <div className="min-h-screen bg-black text-white p-8 flex flex-col items-center justify-center font-sans">
      <div className="max-w-2xl w-full bg-gray-900 p-8 rounded-3xl border border-gray-800 text-center">
        <h1 className="text-3xl font-black text-lime-400 mb-6">הפרוטוקול שלך מוכן!</h1>
        <p className="text-gray-400 mb-2">עבור יעד: <span className="font-bold text-white">{goal}</span></p>
        <p className="text-gray-400 mb-8">ברמה: <span className="font-bold text-white">{level}</span></p>
        
        <div className="bg-black p-6 rounded-2xl border border-lime-500/20 mb-8">
          <p className="text-xl font-bold text-lime-400">{recommendation}</p>
        </div>

        <button 
          onClick={() => window.location.href = '/'}
          className="bg-gray-800 hover:bg-gray-700 text-white font-bold py-3 px-8 rounded-xl transition"
        >
          חזרה לדף הבית
        </button>
      </div>
    </div>
  );
}
